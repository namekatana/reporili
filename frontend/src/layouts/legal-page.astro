---
import "../styles/global.css";
import CustomScrollbar from "../components/custom-scrollbar.svelte";
import SiteFooter from "../components/site-footer.svelte";
import {
  legalLastUpdated,
  legalNav,
  resolveLegalNavItem,
  type LegalDocId,
} from "../lib/legal-meta";
import {
  buildJsonLd,
  resolveSiteUrl,
  siteName,
} from "../lib/site-seo";

type LegalPageProps = {
  title: string;
  description: string;
  activeDoc: LegalDocId;
};

const { title, description, activeDoc } = Astro.props;
const doc = resolveLegalNavItem(activeDoc);

const siteUrl = resolveSiteUrl();
const pageUrl = new URL(Astro.url.pathname, siteUrl).href;
const ogImageUrl = new URL("/og.jpg", siteUrl).href;
const jsonLd = buildJsonLd(siteUrl, pageUrl);
const googleVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content={siteName} />
    <meta name="theme-color" content="#080808" />
    {googleVerification && <meta name="google-site-verification" content={googleVerification} />}
    <link rel="canonical" href={pageUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content={siteName} />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" type="image/png" href="/favicon.png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <title>{title}</title>
  </head>
  <body>
    <CustomScrollbar variant="site" client:load>
      <div class="legal-page">
        <header class="legal-topbar">
          <a class="legal-brand" href="/">
            <picture>
              <source srcset="/logo.webp" type="image/webp" />
              <img class="legal-logo" src="/logo.png" alt="Reporili" width="30" height="30" />
            </picture>
            <span class="legal-brand-divider" aria-hidden="true"></span>
            <span class="legal-brand-name">Reporili</span>
          </a>
          <span class="legal-tag">Beta</span>
        </header>

        <main class="legal-main">
          <section class="legal-hero">
            <a class="legal-back" href="/">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path
                  d="M15 18l-6-6 6-6"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
              Back to generator
            </a>

            <p class="legal-eyebrow">Legal</p>
            <h1 class="legal-headline">{doc.label}</h1>
            <p class="legal-subline">{doc.subtitle}</p>

            <div class="legal-meta-row">
              <span class="legal-updated-pill">Updated {legalLastUpdated}</span>
              <span class="legal-notice-pill">AI drafts, not a law firm</span>
            </div>
          </section>

          <nav class="legal-nav" aria-label="Legal documents">
            {
              legalNav.map((item) => (
                <a
                  class={`legal-nav-link${item.id === activeDoc ? " active" : ""}`}
                  href={item.href}
                  aria-current={item.id === activeDoc ? "page" : undefined}
                >
                  {item.shortLabel}
                </a>
              ))
            }
          </nav>

          <article class="legal-article prose-doc prose-legal">
            <slot />
          </article>

          <p class="legal-footer-note">Last updated {legalLastUpdated}</p>
        </main>

        <SiteFooter client:load />
      </div>
    </CustomScrollbar>
  </body>
</html>

<style>
  .legal-page {
    display: flex;
    flex-direction: column;
    min-height: 100%;
  }

  .legal-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1120px;
    width: 100%;
    margin: 0 auto;
    padding: 1.25rem 2rem 0;
  }

  .legal-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: var(--color-bright);
  }

  .legal-logo {
    display: block;
    width: 30px;
    height: 30px;
    object-fit: contain;
  }

  .legal-brand-divider {
    width: 1px;
    height: 18px;
    background: #333;
    border-radius: 1px;
    flex-shrink: 0;
  }

  .legal-brand-name {
    font-size: 1rem;
    font-weight: 600;
  }

  .legal-tag {
    padding: 0.3rem 0.75rem;
    background: var(--color-float);
    border-radius: var(--radius-pill);
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .legal-main {
    flex: 1;
    max-width: 1120px;
    width: 100%;
    margin: 0 auto;
    padding: 1.5rem 2rem 3rem;
  }

  .legal-hero {
    padding: 0.5rem 0 1.75rem;
  }

  .legal-back {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-bottom: 1.25rem;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .legal-back:hover {
    color: var(--color-bright);
  }

  .legal-eyebrow {
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--color-muted);
    margin-bottom: 0.75rem;
  }

  .legal-headline {
    font-size: clamp(1.85rem, 4.5vw, 2.75rem);
    font-weight: 700;
    color: var(--color-bright);
    line-height: 1.12;
    letter-spacing: -0.03em;
    margin-bottom: 0.85rem;
    max-width: 18ch;
  }

  .legal-subline {
    font-size: 1.02rem;
    color: var(--color-soft);
    line-height: 1.65;
    max-width: 52ch;
    margin-bottom: 1.25rem;
  }

  .legal-meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .legal-updated-pill,
  .legal-notice-pill {
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 0.85rem;
    border-radius: var(--radius-pill);
    font-size: 0.76rem;
    font-weight: 500;
  }

  .legal-updated-pill {
    background: var(--color-surface);
    color: var(--color-soft);
  }

  .legal-notice-pill {
    background: var(--color-float);
    color: var(--color-muted);
  }

  .legal-nav {
    display: flex;
    gap: 0.45rem;
    margin-bottom: 1rem;
    padding: 0.35rem;
    background: var(--color-surface);
    border-radius: var(--radius-panel);
    width: fit-content;
    max-width: 100%;
    overflow-x: auto;
  }

  .legal-nav-link {
    flex-shrink: 0;
    padding: 0.65rem 1.1rem;
    border-radius: calc(var(--radius-panel) - 6px);
    font-size: 0.84rem;
    font-weight: 500;
    color: var(--color-muted);
    text-decoration: none;
    transition: background 0.2s, color 0.2s;
  }

  .legal-nav-link:hover {
    color: var(--color-bright);
    background: var(--color-float);
  }

  .legal-nav-link.active {
    background: var(--color-elevated);
    color: var(--color-bright);
  }

  .legal-article {
    padding: 2rem 2.15rem;
    background: var(--color-surface);
    border-radius: calc(var(--radius-panel) + 4px);
  }

  .legal-footer-note {
    margin-top: 1.25rem;
    padding-left: 0.25rem;
    font-size: 0.78rem;
    color: var(--color-muted);
  }

  @media (max-width: 900px) {
    .legal-headline {
      max-width: none;
    }

    .legal-nav {
      width: 100%;
    }
  }

  @media (max-width: 700px) {
    .legal-topbar,
    .legal-main {
      padding-left: 1.25rem;
      padding-right: 1.25rem;
    }

    .legal-article {
      padding: 1.35rem 1.2rem;
    }

    .legal-nav-link {
      flex: 1;
      text-align: center;
      padding: 0.6rem 0.75rem;
    }
  }
</style>
