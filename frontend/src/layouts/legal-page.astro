---
import "../styles/global.css";
import CustomScrollbar from "../components/custom-scrollbar.svelte";
import SiteFooter from "../components/site-footer.svelte";
import { legalLastUpdated } from "../lib/legal-meta";
import {
  buildJsonLd,
  defaultDescription,
  resolveSiteUrl,
  siteName,
} from "../lib/site-seo";

type LegalPageProps = {
  title: string;
  description: string;
  documentTitle: string;
};

const { title, description, documentTitle } = Astro.props;

const siteUrl = resolveSiteUrl();
const pageUrl = new URL(Astro.url.pathname, siteUrl).href;
const ogImageUrl = new URL("/og.jpg", siteUrl).href;
const jsonLd = buildJsonLd(siteUrl, pageUrl);
const googleVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content={siteName} />
    <meta name="theme-color" content="#080808" />
    {googleVerification && <meta name="google-site-verification" content={googleVerification} />}
    <link rel="canonical" href={pageUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content={siteName} />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" type="image/png" href="/favicon.png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <title>{title}</title>
  </head>
  <body>
    <CustomScrollbar variant="site" client:load>
      <div class="legal-page">
        <header class="legal-topbar">
          <a class="legal-brand" href="/">
            <picture>
              <source srcset="/logo.webp" type="image/webp" />
              <img class="legal-logo" src="/logo.png" alt="Reporili" width="28" height="28" />
            </picture>
            <span class="legal-brand-name">Reporili</span>
          </a>
        </header>

        <main class="legal-main">
          <article class="legal-article prose-doc">
            <p class="legal-updated">Last updated: {legalLastUpdated}</p>
            <h1>{documentTitle}</h1>
            <slot />
            <p class="legal-footer-note">Last updated: {legalLastUpdated}</p>
          </article>
        </main>

        <SiteFooter client:load />
      </div>
    </CustomScrollbar>
  </body>
</html>

<style>
  .legal-page {
    display: flex;
    flex-direction: column;
    min-height: 100%;
  }

  .legal-topbar {
    max-width: 760px;
    width: 100%;
    margin: 0 auto;
    padding: 1.25rem 2rem 0;
  }

  .legal-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    text-decoration: none;
    color: var(--color-bright);
  }

  .legal-logo {
    display: block;
    width: 28px;
    height: 28px;
    object-fit: contain;
  }

  .legal-brand-name {
    font-size: 0.95rem;
    font-weight: 600;
  }

  .legal-main {
    flex: 1;
    max-width: 760px;
    width: 100%;
    margin: 0 auto;
    padding: 1.5rem 2rem 2.5rem;
  }

  .legal-article {
    padding: 1.75rem 1.85rem;
    background: var(--color-surface);
    border-radius: calc(var(--radius-panel) + 4px);
  }

  .legal-updated {
    font-size: 0.82rem;
    color: var(--color-muted);
    margin-bottom: 1rem;
  }

  .legal-footer-note {
    margin-top: 2rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-elevated);
    font-size: 0.82rem;
    color: var(--color-muted);
  }

  @media (max-width: 700px) {
    .legal-topbar,
    .legal-main {
      padding-left: 1.25rem;
      padding-right: 1.25rem;
    }

    .legal-article {
      padding: 1.35rem 1.25rem;
    }
  }
</style>
